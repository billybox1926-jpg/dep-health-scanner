# Copy this file to your local environment file if the project needs runtime configuration.
# Keep real secrets out of Git.

# Application environment (development, staging, production)
APP_ENV=development

# Log level (debug, info, warning, error)
LOG_LEVEL=info

# Cache directory for vulnerability and registry metadata (optional)
# DEP_CACHE_DIR=~/.cache/dep-health-scanner

# API endpoints (override defaults if needed)
# OSV_API_URL=https://api.osv.dev/v1
# NPM_REGISTRY_URL=https://registry.npmjs.org
# CARGO_REGISTRY_URL=https://crates.io/api/v1

# Example placeholder values only. Replace locally as needed.
EXAMPLE_API_URL=https://example.local
EXAMPLE_API_KEY=YOUR_API_KEY_HERE
